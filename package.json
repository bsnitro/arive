  "dependencies": {
    "axios": "^1.9.0",
    "dotenv": "^16.6.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^24.0.0",
    "@vercel/node": "^5.3.4",
    "eslint": "^9.23.0",
    "tsx": "^4.19.4",
    "typescript-eslint": "^8.29.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
